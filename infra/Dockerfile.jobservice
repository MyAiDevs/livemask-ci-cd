FROM golang:1.25-alpine AS builder

ARG JOB_SERVICE_REPO_URL=https://github.com/MyAiDevs/livemask-job-service.git
ARG JOB_SERVICE_REF=dev

RUN apk add --no-cache git ca-certificates
WORKDIR /src
RUN git clone --depth 1 --branch "${JOB_SERVICE_REF}" "${JOB_SERVICE_REPO_URL}" .
RUN go build -o /out/job-service ./cmd/job-service

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /out/job-service /usr/local/bin/job-service
ENV PORT=19191
EXPOSE 19191
ENTRYPOINT ["/usr/local/bin/job-service"]
